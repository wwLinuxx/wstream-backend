# HTTP to HTTPS redirect
server {
    listen 80;
    server_name localhost;
    
    root /var/www/html;
    index index.nginx-debian.html;
    
    # / to /api redirect
    location = / {
        return 301 /api;
    }
    
    # Static content
    location / {
        try_files $uri $uri/ /index.html;
    }
    
    # Error logging
    error_log /var/log/nginx/default-error.log crit;
    access_log /var/log/nginx/default-access.log;
}